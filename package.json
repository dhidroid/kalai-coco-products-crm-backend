  "description": "Express API with PostgreSQL, JWT Auth, and Role-Based Access Control",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
