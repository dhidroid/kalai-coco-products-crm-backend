{
  "name": "kalai-coco-api",
  "version": "1.0.0",
  "description": "Express API with PostgreSQL, JWT Auth, and Role-Based Access Control",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "tsx src/index.ts",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:seed": "node dist/database/seed.js",
    "postinstall": "node -e \"if(process.env.NODE_ENV === 'production') { console.log('Skipping chromium install'); } else { console.log('Dev environment'); }\""
  },
  "keywords": [
    "express",
    "typescript",
    "postgresql",
    "jwt",
    "auth",
    "role-based-access-control"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@sparticuz/chromium": "^129.0.0",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mustache": "^4.2.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "puppeteer-core": "^24.40.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
