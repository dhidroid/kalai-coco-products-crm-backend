    "express-async-errors": "^3.1.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "mustache": "^4.2.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.8.0",
    "puppeteer": "^21.11.0",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^4.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^8.50.0",
